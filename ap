-- Settings
local Prefix = ":"
local LocalPlayer = game:GetService("Players").LocalPlayer

-- Optimized Player Finder
local function GetPlayer(name)
    name = name:lower()
    for _, p in ipairs(game:GetService("Players"):GetPlayers()) do
        if p.Name:lower():sub(1, #name) == name or p.DisplayName:lower():sub(1, #name) == name then
            return p
        end
    end
end

-- The "Functional" Logic
local function ExecuteCommand(msg)
    local args = msg:lower():split(" ")
    if args[1]:sub(1,1) ~= Prefix then return end
    
    local cmd = args[1]:sub(2)
    local target = GetPlayer(args[2] or "")
    
    if not target or not target.Character then return end
    local hrp = target.Character:FindFirstChild("HumanoidRootPart")
    local myHRP = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")

    if cmd == "kill" then
        -- Method: Voiding (Most reliable for FE)
        if hrp then
            local oldCFrame = hrp.CFrame
            hrp.CFrame = CFrame.new(0, -500, 0) -- Send them to the void
            task.wait(0.2)
            hrp.CFrame = oldCFrame -- Bring them back so they actually die/reset
        end

    elseif cmd == "fling" or cmd == "jail" then
        -- Method: Velocity Injection
        -- This tricks the server into thinking the player hit something at Mach 10
        if hrp and myHRP then
            local velocity = Instance.new("BodyVelocity")
            velocity.Velocity = Vector3.new(999999, 999999, 999999)
            velocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
            velocity.Parent = hrp
            task.wait(0.1)
            velocity:Destroy()
        end

    elseif cmd == "bring" then
        -- Only works if you have Network Ownership (e.g. they are sitting in a car you own)
        if hrp and myHRP then
            hrp.CFrame = myHRP.CFrame * CFrame.new(0, 0, -3)
        end
        
    elseif cmd == "goto" then
        if hrp and myHRP then
            myHRP.CFrame = hrp.CFrame * CFrame.new(0, 0, 3)
        end
    end
end

-- Listen to your own chat
LocalPlayer.Chatted:Connect(ExecuteCommand)

print("--- Admin Script Loaded ---")
print("Commands: :kill, :fling, :goto, :bring")
