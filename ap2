-- [[ Stealth Admin: Hyperion-Resistant Logic ]] --
local Prefix = ":"
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

local Settings = {
    SpeedValue = 16,
    IsFlying = false,
    Noclip = false,
    Frozen = {}
}

-- Optimized Player Search
local function GetPlayer(name)
    name = (name or ""):lower()
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Name:lower():sub(1, #name) == name or p.DisplayName:lower():sub(1, #name) == name then
            return p
        end
    end
end

-- HEARTBEAT BYPASS: Handles Noclip and Speed without triggering property-watchers
RunService.Heartbeat:Connect(function()
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChildOfClass("Humanoid")

    if hrp and hum then
        -- 1. Stealth Speed: Manual CFrame nudging (Bypasses WalkSpeed checks)
        if Settings.SpeedValue > 16 and hum.MoveDirection.Magnitude > 0 then
            hrp.CFrame = hrp.CFrame + (hum.MoveDirection * (Settings.SpeedValue / 100))
        end

        -- 2. Stealth Noclip: Disables collisions during the physics step
        if Settings.Noclip then
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        end
    end
end)

-- Command Processor
local function Execute(msg)
    local args = msg:split(" ")
    local cmd = args[1]:sub(#Prefix + 1):lower()
    local target = GetPlayer(args[2])
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")

    -- BYPASS: GOTO
    if cmd == "goto" and target and target.Character then
        local tHRP = target.Character:FindFirstChild("HumanoidRootPart")
        if hrp and tHRP then hrp.CFrame = tHRP.CFrame * CFrame.new(0, 0, 3) end

    -- BYPASS: BRING (Uses local physics pull)
    elseif cmd == "bring" and target and target.Character then
        local tHRP = target.Character:FindFirstChild("HumanoidRootPart")
        if tHRP then tHRP.CFrame = hrp.CFrame * CFrame.new(0, 0, -3) end

    -- BYPASS: FREEZE (Continuous CFrame Reset)
    elseif cmd == "freeze" and target then
        Settings.Frozen[target.UserId] = true
        task.spawn(function()
            while Settings.Frozen[target.UserId] do
                local tHRP = target.Character and target.Character:FindFirstChild("HumanoidRootPart")
                if tHRP then tHRP.CFrame = tHRP.CFrame end
                task.wait()
            end
        end)

    elseif cmd == "unfreeze" and target then
        Settings.Frozen[target.UserId] = nil

    -- BYPASS: SPEED SET
    elseif cmd == "speed" then
        Settings.SpeedValue = tonumber(args[2]) or 16

    -- BYPASS: NOCLIP TOGGLE
    elseif cmd == "noclip" then
        Settings.Noclip = not Settings.Noclip
        print("Noclip State: " .. tostring(Settings.Noclip))
    end
end

LocalPlayer.Chatted:Connect(Execute)
print("--- Stealth Admin Initialized ---")
