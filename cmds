-- 2. Scanning Logic
local SERVICES = {
    "Workspace", "Players", "Lighting", "ReplicatedFirst", 
    "ReplicatedStorage", "StarterGui", "StarterPack", "StarterPlayer"
}

local function hasScript(obj)
    if obj:IsA("LuaSourceContainer") then return true end
    for _, child in ipairs(obj:GetChildren()) do
        if hasScript(child) then return true end
    end
    return false
end

local function scan(obj, depth)
    if (obj:IsA("Folder") or obj:IsA("Model")) and not hasScript(obj) then return "" end
    if obj:IsA("BasePart") and not obj:IsA("LuaSourceContainer") then return "" end

    local indent = string.rep("  ", depth)
    local icon = "• "
    
    if obj:IsA("Script") then icon = "📜 " 
    elseif obj:IsA("LocalScript") then icon = "💻 " 
    elseif obj:IsA("ModuleScript") then icon = "📦 " 
    elseif obj:IsA("Folder") or obj:IsA("Model") then icon = "📂 "
    elseif obj:IsA("ServiceProvider") then icon = "⚙️ " 
    end

    local line = indent .. icon .. obj.Name .. " <font color='#888888'>[" .. obj.ClassName .. "]</font>\n"
    
    for _, child in ipairs(obj:GetChildren()) do
        line = line .. scan(child, depth + 1)
    end
    
    return line
end

-- 3. Run Build
task.spawn(function()
    local output = ""
    for _, sName in ipairs(SERVICES) do
        local ok, serv = pcall(game.GetService, game, sName)
        if ok and serv then
            local data = scan(serv, 0)
            if #data > 0 then output = output .. data .. "\n" end
        end
    end
    textLabel.Text = #output > 0 and output or "No scripts found."
end)
