local TextChatService = game:GetService("TextChatService")

-- Configuration
local CHUNK_SIZE = 200 
local SERVICES = {
    "Workspace", 
    "Players", 
    "Lighting",
    "ReplicatedFirst", 
    "ReplicatedStorage", 
    "StarterGui", 
    "StarterPack", 
    "StarterPlayer", 
    "Teams", 
    "SoundService"
}

-- Check if an object contains any scripts at any depth
local function hasScriptDescendant(obj)
    if obj:IsA("LuaSourceContainer") then return true end
    local children = obj:GetChildren()
    for _, child in ipairs(children) do
        if hasScriptDescendant(child) then return true end
    end
    return false
end

-- The Recursive Engine
local function scan(obj, depth)
    -- If it's a folder/model, only show it if it contains a script somewhere inside
    if (obj:IsA("Folder") or obj:IsA("Model") or obj:IsA("Configuration")) and not hasScriptDescendant(obj) then 
        return "" 
    end
    
    -- Ignore physical parts to keep the layout focused on logic
    if obj:IsA("BasePart") and not obj:IsA("LuaSourceContainer") then
        return ""
    end

    local indent = string.rep("  ", depth)
    local icon = "🔹 "
    
    -- Icon logic for scripts and containers
    if obj:IsA("Script") then icon = "📜 " 
    elseif obj:IsA("LocalScript") then icon = "💻 " 
    elseif obj:IsA("ModuleScript") then icon = "📦 " 
    elseif obj:IsA("Folder") or obj:IsA("Model") then icon = "📂 "
    elseif obj:IsA("ServiceProvider") then icon = "⚙️ " -- Icon for Services
    end

    local output = indent .. icon .. obj.Name .. " [" .. obj.ClassName .. "]\n"
    
    for _, child in ipairs(obj:GetChildren()) do
        output = output .. scan(child, depth + 1)
    end
    
    return output
end

local function executeFullScan()
    local bChannel = TextChatService:WaitForChild("TextChannels", 10):WaitForChild("RBXGeneral", 10)
    if not bChannel then return end

    bChannel:DisplaySystemMessage("🛠️ [UNIVERSAL BUILD] Starting Service & Script Scan...")

    for _, serviceName in ipairs(SERVICES) do
        -- Use pcall in case a service isn't accessible in the current environment
        local success, serv = pcall(function() return game:GetService(serviceName) end)
        
        if success and serv then
            -- We scan every service. It will only return text if scripts exist inside.
            local data = scan(serv, 0)
            
            if #data > 0 then
                -- Send the data to chat in readable chunks
                for i = 1, #data, CHUNK_SIZE do
                    local chunk = string.sub(data, i, i + CHUNK_SIZE - 1)
                    bChannel:DisplaySystemMessage(chunk)
                    -- Small wait to prevent "Message Flood" kicks
                    if i % 1000 == 0 then task.wait(0.1) end
                end
            end
        end
    end
    
    bChannel:DisplaySystemMessage("✅ [SCAN COMPLETE]")
end

-- Autobuild: Runs immediately on execution
task.spawn(executeFullScan)
