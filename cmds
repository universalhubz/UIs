textLabel.Parent = scrollingFrame

-- 2. Configuration
local SERVICES = {
    "Workspace", "Players", "Lighting", "ReplicatedFirst", 
    "ReplicatedStorage", "StarterGui", "StarterPack", 
    "StarterPlayer", "Teams", "SoundService"
}

-- 3. Logic Functions
local function hasScriptDescendant(obj)
    if obj:IsA("LuaSourceContainer") then return true end
    for _, child in ipairs(obj:GetChildren()) do
        if hasScriptDescendant(child) then return true end
    end
    return false
end

local function scan(obj, depth)
    if (obj:IsA("Folder") or obj:IsA("Model")) and not hasScriptDescendant(obj) then return "" end
    if obj:IsA("BasePart") and not obj:IsA("LuaSourceContainer") then return "" end

    local indent = string.rep("    ", depth)
    local icon = "• "
    
    if obj:IsA("Script") then icon = "📜 " 
    elseif obj:IsA("LocalScript") then icon = "💻 " 
    elseif obj:IsA("ModuleScript") then icon = "📦 " 
    elseif obj:IsA("Folder") or obj:IsA("Model") then icon = "📂 "
    elseif obj:IsA("ServiceProvider") then icon = "⚙️ " 
    end

    local line = indent .. icon .. obj.Name .. " <font color='#aaaaaa'>[" .. obj.ClassName .. "]</font>\n"
    
    for _, child in ipairs(obj:GetChildren()) do
        line = line .. scan(child, depth + 1)
    end
    
    return line
end

-- 4. Execute
task.spawn(function()
    local finalOutput = "<b>[GAME EXPLORER SCRIPT LAYOUT]</b>\n\n"
    
    for _, serviceName in ipairs(SERVICES) do
        local success, serv = pcall(function() return game:GetService(serviceName) end)
        if success and serv then
            local serviceData = scan(serv, 0)
            if #serviceData > 0 then
                finalOutput = finalOutput .. serviceData .. "\n"
            end
        end
    end
    
    textLabel.Text = finalOutput
end)
