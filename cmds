local TextChatService = game:GetService("TextChatService")

-- Configuration
local CHUNK_SIZE = 200 
local SERVICES = {
    "Workspace", "Players", "ReplicatedFirst", "ReplicatedStorage", 
    "StarterGui", "StarterPack", "StarterPlayer", "Teams", "SoundService"
}

-- Check if an object or any of its descendants is a script
local function hasScriptDescendant(obj)
    if obj:IsA("LuaSourceContainer") then return true end
    for _, child in ipairs(obj:GetChildren()) do
        if hasScriptDescendant(child) then return true end
    end
    return false
end

-- The Recursive Engine (Script-Focused)
local function scanScripts(obj, depth)
    -- If this branch has zero scripts, don't even look at it
    if not hasScriptDescendant(obj) then return "" end

    local indent = string.rep("  ", depth)
    local output = ""
    
    -- Determine the Icon
    local icon = "🔹 "
    if obj:IsA("Script") then icon = "📜 " 
    elseif obj:IsA("LocalScript") then icon = "💻 " 
    elseif obj:IsA("ModuleScript") then icon = "📦 " 
    elseif obj:IsA("Folder") or obj:IsA("Model") then icon = "📂 " end

    output = indent .. icon .. obj.Name .. " [" .. obj.ClassName .. "]\n"
    
    for _, child in ipairs(obj:GetChildren()) do
        output = output .. scanScripts(child, depth + 1)
    end
    
    return output
end

local function executeScriptExport()
    local bChannel = TextChatService:WaitForChild("TextChannels", 10):WaitForChild("RBXGeneral", 10)
    if not bChannel then return end

    bChannel:DisplaySystemMessage("🔍 [SCRIPT EXPLORER] Scanning for Lua Source...")

    for _, serviceName in ipairs(SERVICES) do
        local serv = game:GetService(serviceName)
        if serv then
            local data = scanScripts(serv, 0)
            
            if #data > 0 then
                -- Chunking to bypass chat limits
                for i = 1, #data, CHUNK_SIZE do
                    local chunk = string.sub(data, i, i + CHUNK_SIZE - 1)
                    bChannel:DisplaySystemMessage(chunk)
                    if i % 1000 == 0 then task.wait(0.1) end
                end
            end
        end
    end
    
    bChannel:DisplaySystemMessage("✅ [SCRIPT EXPLORER] Scan Complete.")
end

-- Autobuild
task.spawn(executeScriptExport)
