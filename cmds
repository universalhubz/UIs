-- 2. Fast Scanning Logic
local SERVICES = {"Workspace", "Players", "Lighting", "ReplicatedFirst", "ReplicatedStorage", "StarterGui", "StarterPack", "StarterPlayer"}

local function getTurboLayout()
    local finalStr = ""
    
    for _, sName in ipairs(SERVICES) do
        local serv = game:GetService(sName)
        title.Text = "Scanning " .. sName .. "..."
        task.wait() -- Keep UI alive
        
        -- Get ALL scripts at once
        local descendants = serv:GetDescendants()
        local scriptFoundInService = false
        local serviceOutput = "<b>[" .. sName .. "]</b>\n"
        
        for i, obj in ipairs(descendants) do
            if obj:IsA("LuaSourceContainer") then
                scriptFoundInService = true
                
                -- Construct path
                local path = obj.Name
                local parent = obj.Parent
                while parent ~= serv do
                    path = parent.Name .. " > " .. path
                    parent = parent.Parent
                end
                
                local icon = obj:IsA("LocalScript") and "💻" or (obj:IsA("ModuleScript") and "📦" or "📜")
                serviceOutput = serviceOutput .. "  " .. icon .. " " .. path .. " <font color='#888888'>[" .. obj.ClassName .. "]</font>\n"
            end
            
            -- Yield only occasionally to maintain high speed
            if i % 500 == 0 then task.wait() end
        end
        
        if scriptFoundInService then
            finalStr = finalStr .. serviceOutput .. "\n"
        end
    end
    
    return finalStr
end

-- 3. Run
task.spawn(function()
    local start = tick()
    local results = getTurboLayout()
    local duration = math.floor((tick() - start) * 100) / 100
    
    title.Text = "Scan Finished in " .. duration .. "s"
    textLabel.Text = #results > 0 and results or "No scripts found."
end)
