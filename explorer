-- 2. Heavy-Duty Scanning Engine
local SERVICES = {"Workspace", "Players", "Lighting", "ReplicatedStorage", "StarterGui"}

local function createLine(text, order)
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 0, 16)
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.fromRGB(200, 200, 200)
    label.Text = text
    label.Font = Enum.Font.Code
    label.TextSize = 12
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.LayoutOrder = order
    label.RichText = true
    label.Parent = scroll
end

local function heavyScan()
    local total = 0
    
    for _, sName in ipairs(SERVICES) do
        local serv = game:GetService(sName)
        createLine("<b>[" .. sName .. "]</b>", total)
        
        local stack = {{serv, 0}}
        while #stack > 0 do
            local current = table.remove(stack)
            local obj, depth = current[1], current[2]
            
            if obj ~= serv then
                total = total + 1
                local indent = string.rep("  ", depth)
                local icon = obj:IsA("LuaSourceContainer") and "📜" or "🔹"
                
                -- Optimization: Only create labels for scripts/folders if the game is TOO big
                -- If you want EVERY part, keep the line below.
                createLine(indent .. icon .. " " .. obj.Name .. " <font color='#555'>[" .. obj.ClassName .. "]</font>", total)
            end
            
            -- Dynamic Yielding: Higher threshold for massive games
            if total % 400 == 0 then 
                title.Text = "Rendering: " .. total .. " objects..."
                task.wait() 
            end
            
            local children = obj:GetChildren()
            for i = #children, 1, -1 do
                table.insert(stack, {children[i], depth + 1})
            end
        end
    end
    title.Text = "Scan Complete: " .. total .. " items"
end

-- 3. Controls
toggleBtn.MouseButton1Click:Connect(function() mainFrame.Visible = not mainFrame.Visible end)

task.spawn(heavyScan)
