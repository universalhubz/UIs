-- 2. Turbo Logic
local SERVICES = {"Workspace", "Players", "Lighting", "ReplicatedFirst", "ReplicatedStorage", "StarterGui", "StarterPack", "StarterPlayer"}

local function getIcon(obj)
    if obj:IsA("LuaSourceContainer") then return "📜"
    elseif obj:IsA("Folder") then return "📂"
    elseif obj:IsA("Model") then return "🧱"
    elseif obj:IsA("BasePart") then return "◻️"
    else return "🔹" end
end

local function fastScan()
    local log = {}
    local total = 0
    
    for _, sName in ipairs(SERVICES) do
        local serv = game:GetService(sName)
        table.insert(log, "<b>[" .. sName .. "]</b>")
        
        -- Non-recursive stack for max speed
        local stack = {{serv, 0}}
        while #stack > 0 do
            local current = table.remove(stack)
            local obj, depth = current[1], current[2]
            
            if obj ~= serv then
                local indent = string.rep("  ", depth)
                table.insert(log, indent .. getIcon(obj) .. " " .. obj.Name .. " <font color='#666'>[" .. obj.ClassName .. "]</font>")
            end
            
            total = total + 1
            -- Yield only when necessary to keep UI responsive
            if total % 2000 == 0 then 
                title.Text = "Scanning: " .. total
                task.wait() 
            end
            
            local children = obj:GetChildren()
            for i = #children, 1, -1 do
                table.insert(stack, {children[i], depth + 1})
            end
        end
        table.insert(log, "") -- Spacer
    end
    
    textLabel.Text = table.concat(log, "\n")
    title.Text = "Scan Finished (" .. total .. " items)"
end

-- 3. Interactivity
