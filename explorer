-- 2. Performance Scan Logic
local SERVICES = {"Workspace", "Players", "Lighting", "ReplicatedFirst", "ReplicatedStorage", "StarterGui", "StarterPack", "StarterPlayer"}

local function getIcon(obj)
	if obj:IsA("Script") then return "📜"
	elseif obj:IsA("LocalScript") then return "💻"
	elseif obj:IsA("ModuleScript") then return "📦"
	elseif obj:IsA("Folder") then return "📂"
	elseif obj:IsA("Model") then return "🧱"
	elseif obj:IsA("BasePart") then return "◻️"
	else return "🔹" end
end

local function performScan()
	local fullLog = {}
	local totalCount = 0
	
	for _, sName in ipairs(SERVICES) do
		local serv = game:GetService(sName)
		table.insert(fullLog, "<b>[" .. sName .. "]</b>")
		
		-- Use a stack to avoid recursion depth issues
		local stack = {{serv, 1}}
		while #stack > 0 do
			local data = table.remove(stack)
			local obj, depth = data[1], data[2]
			
			if obj ~= serv then
				local indent = string.rep("  ", depth)
				table.insert(fullLog, indent .. getIcon(obj) .. " " .. obj.Name .. " <font color='#777777'>[" .. obj.ClassName .. "]</font>")
			end
			
			totalCount = totalCount + 1
			if totalCount % 1500 == 0 then 
				title.Text = "Scanning: " .. totalCount
				task.wait() 
			end
			
			local children = obj:GetChildren()
			for i = #children, 1, -1 do
				table.insert(stack, {children[i], depth + 1})
			end
		end
		table.insert(fullLog, "") -- Spacer between services
	end
	
	textLabel.Text = table.concat(fullLog, "\n")
	title.Text = "Explorer (" .. totalCount .. " items)"
end

