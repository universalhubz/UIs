-- 2. Logic & States
local SERVICES = {"Workspace", "Players", "Lighting", "ReplicatedStorage", "StarterGui", "StarterPack"}
local isScanning = false
local stopRequested = false

local function createLine(text, color)
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 0, 20)
    label.BackgroundTransparency = 1
    label.TextColor3 = color or Color3.fromRGB(200, 200, 200)
    label.Text = text
    label.Font = Enum.Font.Code
    label.TextSize = 13
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.RichText = true
    label.Parent = scroll
end

local function scan(filter)
    if isScanning then return end
    isScanning = true
    stopRequested = false
    
    -- Clear current list
    for _, v in ipairs(scroll:GetChildren()) do
        if v:IsA("TextLabel") then v:Destroy() end
    end

    local total = 0
    local searchTerm = filter and filter:lower() or ""

    for _, sName in ipairs(SERVICES) do
        if stopRequested then break end
        
        local serv = game:GetService(sName)
        local stack = {{serv, 1}}
        
        while #stack > 0 do
            if stopRequested then break end
            
            local current = table.remove(stack)
            local obj, depth = current[1], current[2]

            -- FILTER: Scripts, Models, Folders
            if obj ~= serv and (obj:IsA("LuaSourceContainer") or obj:IsA("Model") or obj:IsA("Folder")) then
                local nameMatch = obj.Name:lower():find(searchTerm)
                
                if searchTerm == "" or nameMatch then
                    local indent = string.rep("  ", depth)
                    local icon = obj:IsA("LuaSourceContainer") and "📜 " or (obj:IsA("Model") and "🧱 " or "📂 ")
                    local color = obj:IsA("LuaSourceContainer") and Color3.fromRGB(100, 200, 255) or Color3.fromRGB(200, 200, 200)
                    
                    createLine(indent .. icon .. obj.Name .. " <font color='#666'>[" .. obj.ClassName .. "]</font>", color)
                    total = total + 1
                end
            end

            -- Performance Yield
            if total % 300 == 0 then 
                title.Text = "Rendering: " .. total .. (stopRequested and " (STOPPED)" or "")
                task.wait() 
            end

            for _, child in ipairs(obj:GetChildren()) do
                table.insert(stack, {child, depth + 1})
            end
        end
    end
    
    title.Text = stopRequested and "Stopped at " .. total or "Found: " .. total
    isScanning = false
end

-- 3. Events
stopBtn.MouseButton1Click:Connect(function()
    stopRequested = true
end)

searchBar.FocusLost:Connect(function(enterPressed)
    if enterPressed then
        scan(searchBar.Text)
    end
end)

-- Initial scan (Optional, can be left blank for user to search first)
task.spawn(function() scan("") end)
