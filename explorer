-- 2. Performance Logic
local SERVICES = {"Workspace", "Players", "Lighting", "ReplicatedStorage", "StarterGui", "StarterPack", "StarterPlayer"}
local currentScanID = 0

local function createLine(text, color)
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 0, 20)
    label.BackgroundTransparency = 1
    label.TextColor3 = color or Color3.fromRGB(200, 200, 200)
    label.Text = "  " .. text
    label.Font = Enum.Font.Code
    label.TextSize = 14
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.RichText = true
    label.Parent = scroll
end

local function runScan(filterText)
    currentScanID = currentScanID + 1
    local myScanID = currentScanID
    
    -- Clear UI safely
    for _, item in ipairs(scroll:GetChildren()) do
        if item:IsA("TextLabel") then item:Destroy() end
    end

    local foundCount = 0
    local searchTerm = filterText:lower()

    for _, sName in ipairs(SERVICES) do
        if myScanID ~= currentScanID then return end
        local success, service = pcall(game.GetService, game, sName)
        
        if success and service then
            createLine("<b>[" .. sName .. "]</b>", Color3.fromRGB(255, 215, 0))
            
            local stack = {{service, 1}}
            while #stack > 0 do
                if myScanID ~= currentScanID then return end
                
                local node = table.remove(stack)
                local obj, depth = node[1], node[2]

                if obj ~= service and (obj:IsA("LuaSourceContainer") or obj:IsA("Model") or obj:IsA("Folder")) then
                    -- SEARCH LOGIC
                    if searchTerm == "" or obj.Name:lower():find(searchTerm) then
                        local indent = string.rep("  ", depth)
                        local icon = obj:IsA("LuaSourceContainer") and "📜" or (obj:IsA("Model") and "🧱" or "📂")
                        local color = obj:IsA("LuaSourceContainer") and Color3.fromRGB(100, 200, 255) or Color3.fromRGB(200, 200, 200)
                        
                        createLine(indent .. icon .. " " .. obj.Name .. " <font color='#666'>[" .. obj.ClassName .. "]</font>", color)
                        foundCount = foundCount + 1
                    end
                end

                if foundCount % 350 == 0 then 
                    title.Text = "Rendering: " .. foundCount
                    task.wait() 
                end

                local children = obj:GetChildren()
                for i = #children, 1, -1 do
                    table.insert(stack, {children[i], depth + 1})
                end
            end
        end
    end
    title.Text = "Found: " .. foundCount
end

-- 3. Interactivity
stopBtn.MouseButton1Click:Connect(function()
    currentScanID = currentScanID + 1
    title.Text = "Scan Halted"
end)

viewAllBtn.MouseButton1Click:Connect(function()
    searchBar.Text = ""
    runScan("")
end)

searchBar:GetPropertyChangedSignal("Text"):Connect(function()
    local text = searchBar.Text
    task.delay(0.6, function()
        if searchBar.Text == text and text ~= "" then
            runScan(text)
        end
    end)
end)

-- Initial Auto-Scan
task.spawn(function() runScan("") end)
