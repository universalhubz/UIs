-- 2. Logic: Filtering for Scripts, Models, and Services
local SERVICES = {"Workspace", "Players", "Lighting", "ReplicatedStorage", "StarterGui", "StarterPack", "StarterPlayer"}

local function createLine(text, order, color)
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 0, 18)
    label.BackgroundTransparency = 1
    label.TextColor3 = color or Color3.fromRGB(200, 200, 200)
    label.Text = text
    label.Font = Enum.Font.Code
    label.TextSize = 13
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.LayoutOrder = order
    label.RichText = true
    label.Parent = scroll
end

local function performFocusedScan()
    -- Clear existing list if refreshing
    for _, child in ipairs(scroll:GetChildren()) do
        if child:IsA("TextLabel") then child:Destroy() end
    end

    local total = 0
    
    for _, sName in ipairs(SERVICES) do
        local serv = game:GetService(sName)
        createLine("<b>⚙️ " .. sName .. "</b>", total, Color3.fromRGB(255, 255, 100))
        total = total + 1
        
        local stack = {{serv, 1}}
        while #stack > 0 do
            local current = table.remove(stack)
            local obj, depth = current[1], current[2]
            
            -- CHECK: Is it a Script, Model, or Folder?
            local isScript = obj:IsA("LuaSourceContainer")
            local isModel = obj:IsA("Model")
            local isFolder = obj:IsA("Folder")

            if obj ~= serv and (isScript or isModel or isFolder) then
                local indent = string.rep("  ", depth)
                local icon = isScript and "📜 " or (isModel and "🧱 " or "📂 ")
                local color = isScript and Color3.fromRGB(120, 180, 255) or Color3.fromRGB(200, 200, 200)
                
                createLine(indent .. icon .. obj.Name .. " <font color='#666'>[" .. obj.ClassName .. "]</font>", total, color)
                total = total + 1
            end
            
            -- Yield for performance
            if total % 500 == 0 then 
                title.Text = "Objects Mapped: " .. total
                task.wait() 
            end
            
            local children = obj:GetChildren()
            for i = #children, 1, -1 do
                table.insert(stack, {children[i], depth + 1})
            end
        end
    end
    title.Text = "Scan Finished (" .. total .. " entries)"
end

-- 3. Controls
toggleBtn.MouseButton1Click:Connect(function() mainFrame.Visible = not mainFrame.Visible end)

task.spawn(performFocusedScan)
