-- DIAGNOSTIC DASH (V7)
local rs = game:GetService("ReplicatedStorage")
local sss = game:GetService("ServerScriptService")
local sps = game:GetService("StarterPlayer"):WaitForChild("StarterPlayerScripts")
local sg = game:GetService("StarterGui")

-- 1. CLEANUP
local function cl(p, n) local o = p:FindFirstChild(n) if o then o:Destroy() end end
cl(rs, "DashEvent") cl(sss, "DashServer") cl(sps, "DashClient") cl(sg, "DashGui")

-- 2. REMOTE EVENT
local dashEvent = Instance.new("RemoteEvent", rs)
dashEvent.Name = "DashEvent"

-- 3. SERVER SCRIPT
local serverScript = Instance.new("Script", sss)
serverScript.Name = "DashServer"
serverScript.Source = [[
local dashEvent = game:GetService("ReplicatedStorage"):WaitForChild("DashEvent")

dashEvent.OnServerEvent:Connect(function(player)
	print("SERVER: Received dash request from " .. player.Name)
	local char = player.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	
	if hrp then
		print("SERVER: Moving Character...")
		local newPos = hrp.CFrame * CFrame.new(0, 0, -30)
		char:PivotTo(newPos)
	else
		warn("SERVER ERROR: HumanoidRootPart not found for " .. player.Name)
	end
end)
]]

-- 4. MOBILE GUI
local dashGui = Instance.new("ScreenGui", sg)
dashGui.Name = "DashGui"
dashGui.ResetOnSpawn = false

local btn = Instance.new("TextButton", dashGui)
btn.Name = "DashButton"
btn.Size = UDim2.new(0, 80, 0, 80)
btn.Position = UDim2.new(0.85, -40, 0.7, -40)
btn.Text = "DASH"
btn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
btn.TextColor3 = Color3.new(1,1,1)
Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 40)

-- 5. LOCAL SCRIPT
local localScript = Instance.new("LocalScript", sps)
localScript.Name = "DashClient"
localScript.Source = [[
local UIS = game:GetService("UserInputService")
local rs = game:GetService("ReplicatedStorage")
local player = game.Players.LocalPlayer

-- Wait for the event to exist
local dashEvent = rs:WaitForChild("DashEvent", 10)

local function doDash()
	if not dashEvent then 
		warn("CLIENT ERROR: DashEvent not found in ReplicatedStorage!")
		return 
	end
	
	print("CLIENT: Firing DashEvent...")
	dashEvent:FireServer()
end

-- Keybind
UIS.InputBegan:Connect(function(i, p) if not p and i.KeyCode == Enum.KeyCode.E then doDash() end end)

-- Button
task.spawn(function()
	local pGui = player:WaitForChild("PlayerGui")
	local gui = pGui:WaitForChild("DashGui")
	gui.DashButton.Activated:Connect(doDash)
end)
]]

print("🛠️ DIAGNOSTIC SETUP READY. Check the Output window while playing!")
