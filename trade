-- 2. Target Logic
local function getDeepValue(obj)
	-- If it's a ValueObject, show what's written inside it
	if obj:IsA("StringValue") or obj:IsA("TextValue") then
		return " = <font color='#ffffff'>\"" .. obj.Value .. "\"</font>"
	elseif obj:IsA("IntValue") or obj:IsA("NumberValue") or obj:IsA("BoolValue") then
		return " = <font color='#ffaa00'>" .. tostring(obj.Value) .. "</font>"
	elseif obj:IsA("ObjectValue") then
		return " = <font color='#aaaaaa'>" .. (obj.Value and obj.Value.Name or "nil") .. "</font>"
	end
	return ""
end

local function updateInspector()
	local target = workspace:FindFirstChild("ComputerScreen", true)
	
	if target then
		local log = {}
		table.insert(log, "<b>[ROOT] " .. target.Name .. " (" .. target.ClassName .. ")</b>")
		table.insert(log, "Path: " .. target:GetFullName())
		table.insert(log, string.rep("—", 20))
		
		local children = target:GetChildren()
		if #children > 0 then
			for _, child in ipairs(children) do
				local valSuffix = getDeepValue(child)
				local icon = child:IsA("RemoteEvent") and "📡 " or (child:IsA("ModuleScript") and "📦 " or "🔹 ")
				table.insert(log, icon .. child.Name .. " <font color='#666'>[" .. child.ClassName .. "]</font>" .. valSuffix)
			end
		else
			table.insert(log, "<i>No children found inside script.</i>")
		end
		
		contentLabel.Text = table.concat(log, "\n")
	else
		contentLabel.Text = "<font color='#ff4444'>[!] TradeMachine not found in Workspace.</font>"
	end
end

-- 3. Auto-Loop (Updates every 1 second for live tracking)
task.spawn(function()
	while true do
		updateInspector()
		task.wait(1)
	end
end)
