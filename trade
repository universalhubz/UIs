-- 2. Deep Search Logic (No FindFirstChild)
local function deepSearch(targetName)
    local stack = {workspace}
    local iterations = 0
    
    while #stack > 0 do
        local current = table.remove(stack)
        iterations = iterations + 1
        
        -- Optimization: Yield every 1000 checks so the game doesn't lag
        if iterations % 1000 == 0 then task.wait() end
        
        if current.Name == targetName then
            return current -- Found it!
        end
        
        -- Add children to the stack to keep searching deeper
        local children = current:GetChildren()
        for _, child in ipairs(children) do
            table.insert(stack, child)
        end
    end
    return nil
end

local function updateDisplay()
    local target = deepSearch("TradeMachine")
    
    if target then
        title.Text = "Target Locked: TradeMachine"
        local log = { "<b>Path:</b> " .. target:GetFullName(), "" }
        
        for _, child in ipairs(target:GetChildren()) do
            local val = ""
            if child:IsA("ValueObject") then
                val = " = <font color='#ffffff'>" .. tostring(child.Value) .. "</font>"
            end
            
            local icon = child:IsA("RemoteEvent") and "📡 " or (child:IsA("ModuleScript") and "📦 " or "🔹 ")
            table.insert(log, icon .. child.Name .. " <font color='#666'>[" .. child.ClassName .. "]</font>" .. val)
        end
        contentLabel.Text = table.concat(log, "\n")
    else
        title.Text = "Searching..."
        contentLabel.Text = "<font color='#ff4444'>TradeMachine not found yet. Crawling workspace...</font>"
    end
end

-- 3. Run Loop
task.spawn(function()
    while true do
        updateDisplay()
        task.wait(2) -- Search every 2 seconds
    end
end)
