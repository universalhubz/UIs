-- 2. Logic to Find and Monitor
local function monitorScript()
    -- Find TradeMachine Model
    local machine = workspace:FindFirstChild("TradeMachine", true)
    if not machine or not machine:IsA("Model") then
        infoLabel.Text = "<font color='#ff4444'>[!] TradeMachine Model not found.</font>"
        return
    end

    -- Find computerscreen Script
    local scr = machine:FindFirstChild("computerscreen", true)
    if not scr then
        infoLabel.Text = "<font color='#ff4444'>[!] computerscreen script missing from " .. machine.Name .. "</font>"
        return
    end

    -- Since we can't read .Source, we read everything ELSE
    local report = {}
    table.insert(report, "<b>[STATUS] Script is Active</b>")
    table.insert(report, "Enabled: " .. tostring(scr.Enabled))
    table.insert(report, "RunContext: " .. tostring(scr.RunContext))
    table.insert(report, "\n<b>[CHILDREN/VARIABLES]</b>")
    
    local children = scr:GetChildren()
    if #children == 0 then
        table.insert(report, "<i>No variables or remotes inside script.</i>")
    else
        for _, child in ipairs(children) do
            local extra = ""
            if child:IsA("ValueObject") then
                extra = " = <font color='#ffffff'>" .. tostring(child.Value) .. "</font>"
            end
            table.insert(report, "🔹 " .. child.Name .. " [" .. child.ClassName .. "]" .. extra)
        end
    end
    
    table.insert(report, "\n<b>[CODE STATUS]</b>")
    table.insert(report, "<font color='#aaaaaa'>The source code is encrypted on the server. To see what the script is DOING, look for RemoteEvents inside it.</font>")
    
    infoLabel.Text = table.concat(report, "\n")
end

-- 3. Live Update Loop
task.spawn(function()
    while true do
        monitorScript()
        task.wait(1)
    end
end)
