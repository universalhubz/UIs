-- Settings
local targetName = "TradeMachine"
local textLabelPath = game:GetService("StarterGui").ScreenGui.TextLabel -- Update if your names are different

-- 1. Find the Script
local targetScript = game.Workspace:FindFirstChild(targetName, true) -- 'true' searches descendants too

-- 2. Find the TextLabel
local label = textLabelPath

if targetScript and targetScript:IsA("LuaSourceContainer") then
    if label and label:IsA("TextLabel") then
        -- Get the actual code from the script
        local scriptCode = targetScript.Source
        
        -- Apply to the TextLabel
        label.Text = scriptCode
        
        print("Successfully synced code from " .. targetName .. " to " .. label.Name)
    else
        warn("Could not find the TextLabel at the specified path.")
    end
else
    warn("Could not find a script named '" .. targetName .. "' in Workspace.")
end
