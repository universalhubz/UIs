-- SERVICES
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")

local player = Players.LocalPlayer
local pGui = player:WaitForChild("PlayerGui")

-- 1. BUILD THE UI STRUCTURE
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "MobileUniversalGUI"
ScreenGui.ResetOnSpawn = false
ScreenGui.Parent = pGui

local MainFrame = Instance.new("Frame")
MainFrame.Name = "MainFrame"
MainFrame.Size = UDim2.new(0, 240, 0, 150)
MainFrame.Position = UDim2.new(0.5, -120, 0.5, -75)
MainFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
MainFrame.BorderSizePixel = 0
MainFrame.Active = true -- Important for dragging
MainFrame.Parent = ScreenGui

local MainCorner = Instance.new("UICorner")
MainCorner.CornerRadius = UDim.new(0, 10)
MainCorner.Parent = MainFrame

local MainStroke = Instance.new("UIStroke")
MainStroke.Thickness = 2
MainStroke.Color = Color3.fromRGB(50, 50, 60)
MainStroke.Parent = MainFrame

local Layout = Instance.new("UIListLayout")
Layout.Padding = UDim.new(0, 10)
Layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
Layout.VerticalAlignment = Enum.VerticalAlignment.Center
Layout.Parent = MainFrame

-- 2. BUTTON & TEXT DESIGN
local function createStyledBtn(name, text, color)
	local btn = Instance.new("TextButton")
	btn.Name = name
	btn.Text = text
	btn.Size = UDim2.new(0.85, 0, 0.35, 0)
	btn.BackgroundColor3 = color
	btn.Font = Enum.Font.GothamBold
	btn.TextColor3 = Color3.fromRGB(255, 255, 255)
	btn.TextSize = 14
	btn.AutoButtonColor = false
	btn.Parent = MainFrame
	
	-- Text Stroke for "Cool" Look
	local ts = Instance.new("UIStroke")
	ts.Thickness = 1
	ts.Color = Color3.fromRGB(0,0,0)
	ts.Transparency = 0.5
	ts.Parent = btn
	
	local bc = Instance.new("UICorner")
	bc.CornerRadius = UDim.new(0, 6)
	bc.Parent = btn
	
	return btn
end

local freezeBtn = createStyledBtn("FreezeBtn", "FREEZE TRADE", Color3.fromRGB(0, 120, 255))
local autoBtn = createStyledBtn("AutoBtn", "AUTO ACCEPT: OFF", Color3.fromRGB(200, 50, 50))

-- 3. INTERACTION LOGIC
local tInfo = TweenInfo.new(0.2, Enum.EasingStyle.Quad)

freezeBtn.MouseButton1Click:Connect(function()
	freezeBtn.Text = "❄️ FROZEN"
	TweenService:Create(freezeBtn, tInfo, {BackgroundColor3 = Color3.fromRGB(100, 200, 255)}):Play()
	task.wait(2)
	freezeBtn.Text = "FREEZE TRADE"
	TweenService:Create(freezeBtn, tInfo, {BackgroundColor3 = Color3.fromRGB(0, 120, 255)}):Play()
end)

local autoOn = false
autoBtn.MouseButton1Click:Connect(function()
	autoOn = not autoOn
	autoBtn.Text = autoOn and "AUTO ACCEPT: ON" or "AUTO ACCEPT: OFF"
	local targetColor = autoOn and Color3.fromRGB(50, 180, 80) or Color3.fromRGB(200, 50, 50)
	TweenService:Create(autoBtn, tInfo, {BackgroundColor3 = targetColor}):Play()
end)

-- 4. UNIVERSAL DRAGGING (PC & MOBILE)
local dragging, dragInput, dragStart, startPos

local function update(input)
	local delta = input.Position - dragStart
	MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

MainFrame.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position
		startPos = MainFrame.Position
		
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

MainFrame.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
		dragInput = input
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if input == dragInput and dragging then
		update(input)
	end
end)
