-- SERVICES
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")

local player = Players.LocalPlayer
local pGui = player:WaitForChild("PlayerGui")

-- 1. BUILD THE MAIN FRAME (Glassmorphism Style)
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "EliteTradeGUI"
ScreenGui.ResetOnSpawn = false
ScreenGui.Parent = pGui

local MainFrame = Instance.new("Frame")
MainFrame.Name = "MainFrame"
MainFrame.Size = UDim2.new(0, 260, 0, 160)
MainFrame.Position = UDim2.new(0.5, -130, 0.5, -80)
MainFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 20) -- Dark Navy Black
MainFrame.BackgroundTransparency = 0.1
MainFrame.BorderSizePixel = 0
MainFrame.Parent = ScreenGui

local MainCorner = Instance.new("UICorner")
MainCorner.CornerRadius = UDim.new(0, 12)
MainCorner.Parent = MainFrame

local MainStroke = Instance.new("UIStroke")
MainStroke.Thickness = 2.5
MainStroke.Color = Color3.fromRGB(45, 45, 55)
MainStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
MainStroke.Parent = MainFrame

local Layout = Instance.new("UIListLayout")
Layout.Padding = UDim.new(0, 12)
Layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
Layout.VerticalAlignment = Enum.VerticalAlignment.Center
Layout.Parent = MainFrame

-- 2. TEXT DESIGN FUNCTION
local function applyTextDesign(textLabel)
	textLabel.Font = Enum.Font.GothamBold
	textLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	textLabel.TextSize = 15
	
	-- Text Shadow Effect
	local stroke = Instance.new("UIStroke")
	stroke.Thickness = 1.5
	stroke.Color = Color3.fromRGB(0, 0, 0)
	stroke.Transparency = 0.6
	stroke.Parent = textLabel
end

-- 3. BUTTON CREATOR
local function createTradeBtn(name, defaultText, color)
	local btn = Instance.new("TextButton")
	btn.Name = name
	btn.Text = defaultText
	btn.Size = UDim2.new(0.85, 0, 0.38, 0)
	btn.BackgroundColor3 = color
	btn.AutoButtonColor = false
	btn.Parent = MainFrame
	
	local btnCorner = Instance.new("UICorner")
	btnCorner.CornerRadius = UDim.new(0, 8)
	btnCorner.Parent = btn
	
	-- Apply the cool text design
	applyTextDesign(btn)
	
	return btn
end

local freezeBtn = createTradeBtn("FreezeBtn", "FREEZE TRADE", Color3.fromRGB(0, 130, 255))
local autoBtn = createTradeBtn("AutoBtn", "AUTO ACCEPT: OFF", Color3.fromRGB(200, 50, 60))

-- 4. INTERACTION LOGIC
local tInfo = TweenInfo.new(0.25, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)

-- Freeze Logic
freezeBtn.MouseButton1Click:Connect(function()
	freezeBtn.Text = "❄️ FROZEN"
	TweenService:Create(freezeBtn, tInfo, {BackgroundColor3 = Color3.fromRGB(110, 210, 255)}):Play()
	
	task.delay(2, function()
		freezeBtn.Text = "FREEZE TRADE"
		TweenService:Create(freezeBtn, tInfo, {BackgroundColor3 = Color3.fromRGB(0, 130, 255)}):Play()
	end)
end)

-- Auto Accept Logic
local autoOn = false
autoBtn.MouseButton1Click:Connect(function()
	autoOn = not autoOn
	if autoOn then
		autoBtn.Text = "AUTO ACCEPT: ON"
		TweenService:Create(autoBtn, tInfo, {BackgroundColor3 = Color3.fromRGB(50, 180, 100)}):Play()
	else
		autoBtn.Text = "AUTO ACCEPT: OFF"
		TweenService:Create(autoBtn, tInfo, {BackgroundColor3 = Color3.fromRGB(200, 50, 60)}):Play()
	end
end)

-- 5. SMOOTH DRAGGING
local dragging, dragInput, dragStart, startPos

MainFrame.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStart = input.Position
		startPos = MainFrame.Position
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then dragging = false end
		end)
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
		local delta = input.Position - dragStart
		MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
	end
end)
